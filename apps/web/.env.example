# URL base del worker (sin slash final).
VITE_WORKER_API_BASE=https://bot.alice.dyorch.com

# Token Bearer aceptado por el worker (mismo valor que el secret API_SHARED_TOKEN
# en Cloudflare). Se empaqueta en el bundle del navegador — la web debe ir
# detrás de Cloudflare Access para no exponerlo a Internet.
VITE_API_SHARED_TOKEN=replace_me

# (Opcional) Numero del bot mostrado en /configuracion. Solo presentacional.
VITE_BOT_PHONE=51987654321
