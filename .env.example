# =============================================================================
# Alice  ·  Variables de entorno
# =============================================================================
#
# Este archivo documenta TODAS las variables que necesita el proyecto.
# Es el unico archivo de envs que se commitea al repo. Copialo a:
#
#   cp .env.example apps/worker/.dev.vars     # para `wrangler dev` en local
#   cp .env.example apps/web/.env.local       # para `vite dev` en local
#
# En produccion no se usan estos archivos:
#   - Worker bot  ->  `pnpm --filter @alice/worker exec wrangler secret put <NAME>`
#   - Worker web  ->  `pnpm --filter web exec wrangler secret put <NAME>`
#
# Para generar cadenas aleatorias seguras:
#   openssl rand -hex 32
#
# =============================================================================


# -----------------------------------------------------------------------------
# WORKER  (apps/worker / alice-bot)
# -----------------------------------------------------------------------------

# --- WhatsApp Cloud API ----------------------------------------------------

# Access token permanente generado via System User en Meta Business.
# IMPORTANTE: NO uses el token temporal de 24 h que aparece en el playground.
# Doc: https://developers.facebook.com/docs/whatsapp/business-management-api/get-started
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phone Number ID que ves en Meta -> WhatsApp -> API Setup.
WHATSAPP_PHONE_ID=123456789012345

# Cadena aleatoria que inventas tu. La pegas tal cual en Meta cuando
# configuras el webhook. El bot la compara contra el query param `hub.verify_token`.
WHATSAPP_VERIFY_TOKEN=replace_with_random_string_32_chars

# App Secret de la app de Meta. Se usa para validar el header X-Hub-Signature-256
# en cada webhook entrante. Meta -> App Settings -> Basic -> App Secret.
WHATSAPP_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# --- Seguridad -------------------------------------------------------------

# Tu numero personal en formato E.164 SIN el signo '+' inicial.
# Ejemplo Peru: 51987654321
# Solo se procesara logica de negocio para mensajes que vengan de este numero.
# El resto se loguea con status='rejected_unknown_sender'.
ALLOWED_PHONE=51987654321

# Token compartido entre el worker web (proxy) y el worker bot para autenticar
# requests a /api/*. El worker web lo envia como `Authorization: Bearer ...`
# desde el lado servidor. Debe coincidir EXACTAMENTE en ambos workers.
# IMPORTANTE: este token NUNCA se incluye en el bundle JS del browser.
API_SHARED_TOKEN=replace_with_random_string_32_chars

# (Opcional) Webhook de Slack/Discord/Telegram para alertas de intrusion.
# Si esta definido, se envia una notificacion cuando un numero distinto al
# ALLOWED_PHONE intenta escribir al bot.
# Dejar vacio si no se quiere alertar.
SECURITY_ALERT_WEBHOOK=

# (Opcional) Dias que se retienen los mensajes en `message_log`.
# Un cron diario purga registros mas antiguos. Default 180.
MESSAGE_LOG_RETENTION_DAYS=180


# --- Localizacion ----------------------------------------------------------

# IANA Time Zone del usuario. Se usa para mostrar fechas, interpretar
# expresiones como "manana 8am" y disparar recordatorios en hora local.
USER_TZ=America/Lima

# Moneda por defecto (ISO 4217). El bot soporta PEN y USD por defecto.
# Si un gasto no especifica moneda, se asume esta.
DEFAULT_CURRENCY=PEN


# -----------------------------------------------------------------------------
# WEB  (apps/web)  ·  desarrollo local
# -----------------------------------------------------------------------------
#
# IMPORTANTE: estas variables NO empiezan con `VITE_`, asi que NO se incluyen
# en el bundle JS del browser. Solo las lee `vite.config.ts` para configurar
# el proxy de desarrollo (`/api/*` -> bot worker con Bearer inyectado).
#
# En produccion el worker web hace el mismo proxy server-side leyendo el
# secret `API_SHARED_TOKEN` configurado con `wrangler secret put`.

# URL del worker bot al que se reenvian las llamadas `/api/*` en dev.
# - Local       :  http://localhost:8787
# - Produccion remota (si quieres testear contra el bot deployado en local):
#                  https://bot.alice.dyorch.com
DEV_BOT_API_BASE=http://localhost:8787

# Mismo valor que el `API_SHARED_TOKEN` del worker bot. Solo lo usa el proxy
# de Vite en dev. Si lo dejas vacio, las llamadas a /api/* iran sin Bearer
# y el worker bot respondera 401.
DEV_API_SHARED_TOKEN=replace_with_random_string_32_chars

# (Opcional) Numero del bot a mostrar en la pagina de configuracion.
# Si lo omites se muestra un placeholder.
VITE_BOT_PHONE=51987654321


# =============================================================================
# Notas finales
# -----------------------------------------------------------------------------
# - Nunca commitees los valores reales. Solo este .env.example debe estar en git.
# - Los archivos .dev.vars y .env.local estan en .gitignore.
# - Para rotar el API_SHARED_TOKEN:
#     1. Generar nuevo valor:  openssl rand -hex 32
#     2. Worker bot:  pnpm --filter @alice/worker exec wrangler secret put API_SHARED_TOKEN
#     3. Worker web:  pnpm --filter web exec wrangler secret put API_SHARED_TOKEN
#     4. Redeploy ambos.
# =============================================================================
