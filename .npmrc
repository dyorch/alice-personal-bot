# pnpm 10/11 dispara ERR_PNPM_IGNORED_BUILDS al final del install si detecta
# scripts no construidos, incluso si estan en `onlyBuiltDependencies`. En la
# CI de Workers Builds no podemos correr `pnpm rebuild` interactivo, asi que
# desactivamos los scripts en el install y los reconstruimos explicitamente
# desde el build command.
ignore-scripts=true
auto-install-peers=true
